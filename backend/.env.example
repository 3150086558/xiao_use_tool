# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
APP_DEBUG=true

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=my_tools
DB_USER=my_tools_user
DB_PASSWORD=change_me_to_strong_password

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET_KEY=change_me_to_a_very_long_random_secret_key_for_jwt_signing
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据库连接加密密钥（用于 db_connections 表密码加密）
DB_CIPHER_KEY=change_me_to_32byte_base64_encryption_key

# Celery 配置
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# CORS 配置（逗号分隔）
CORS_ORIGINS=http://localhost:1111,http://127.0.0.1:1111

# 限流配置
RATE_LIMIT_PER_MINUTE=60
